{% extends 'base.html.twig' %}

{% block title %}Nouvelle cellule - PAS{% endblock %}
{% block page_title %}Nouvelle cellule{% endblock %}

{% block dashboard_body %}
    <section class="page-head">
        <div>
            <span class="eyebrow">Structure</span>
            <h1>Creation d'une cellule</h1>
            <p>Parametrage d'une cellule, de son aile et de sa capacite.</p>
        </div>
        <a class="button" href="{{ path('app_structure_cells') }}">Retour cellules</a>
    </section>

    <section class="form-layout">
        <form class="panel form-panel">
            <div class="panel-header">
                <h2>Informations cellule</h2>
                <span class="tag">Referentiel</span>
            </div>
            <div class="form-grid">
                <label>Numero <input type="text" name="number"></label>
                <label>Batiment <input type="text" name="building"></label>
                <label>Aile <input type="text" name="wing"></label>
                <label>Capacite <input type="number" name="capacity" min="1"></label>
                <label>Statut
                    <select name="status">
                        <option>Available</option>
                        <option>Full</option>
                        <option>Maintenance</option>
                    </select>
                </label>
                <label>Commentaire <input type="text" name="comment"></label>
            </div>
            <div class="form-actions">
                <button class="button button-primary" type="button" disabled>Enregistrer</button>
                <span class="form-state">Sauvegarde back a raccorder</span>
            </div>
        </form>
    </section>
{% endblock %}
