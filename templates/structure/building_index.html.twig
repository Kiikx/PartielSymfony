{% extends 'layout/app.html.twig' %}

{% block title %}Batiments - PAS{% endblock %}
{% block page_eyebrow %}Structure penitentiaire{% endblock %}
{% block page_title %}Batiments{% endblock %}

{% block app_body %}
    <section class="page-head">
        <p>Referentiel des batiments et de leurs ailes.</p>
        {% if is_granted('ROLE_ADMIN') %}
            <div class="button-row">
                <a class="button button-primary" href="{{ path('app_building_new') }}">Nouveau batiment</a>
            </div>
        {% endif %}
    </section>

    <article class="panel">
        {% if buildings is empty %}
            <p class="panel-empty">Aucun batiment enregistre.</p>
        {% else %}
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Nom</th>
                            <th scope="col">Code</th>
                            <th scope="col">Ailes</th>
                            <th scope="col">Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for building in buildings %}
                            <tr>
                                <td><a href="{{ path('app_building_show', { id: building.id }) }}">{{ building.name }}</a></td>
                                <td>{{ building.code }}</td>
                                <td>{{ building.wings|length }}</td>
                                <td><span class="badge {{ building.active ? 'badge-low' : 'badge-neutral' }}">{{ building.active ? 'Actif' : 'Inactif' }}</span></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </article>
{% endblock %}
