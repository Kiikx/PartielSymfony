<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}PAS{% endblock %}</title>
        <link rel="icon" type="image/png" href="{{ asset('logo.png') }}">
        <link rel="shortcut icon" href="{{ asset('favicon.ico') }}">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('styles/pas.css') }}">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </head>
    <body class="{% block body_class %}app-body{% endblock %}">
        {% set currentRoute = app.request.attributes.get('_route') %}
        {% set dashboardRoute = 'app_home' %}
        {% if is_granted('ROLE_ADMIN') %}
            {% set dashboardRoute = 'app_admin_dashboard' %}
        {% elseif is_granted('ROLE_MANAGER') %}
            {% set dashboardRoute = 'app_manager_dashboard' %}
        {% elseif is_granted('ROLE_GUARD') %}
            {% set dashboardRoute = 'app_guard_dashboard' %}
        {% endif %}
        {% set dashboardRoutes = ['app_home', 'app_admin_dashboard', 'app_manager_dashboard', 'app_guard_dashboard'] %}

        {% block body %}
            <details class="mobile-menu">
                <summary aria-label="Ouvrir la navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </summary>
                <nav class="mobile-nav" aria-label="Navigation mobile">
                    <a class="side-link {{ currentRoute in dashboardRoutes ? 'is-active' }}" href="{{ path(dashboardRoute) }}">
                        <svg class="side-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 13h7V4H4v9Zm0 7h7v-5H4v5Zm9 0h7v-9h-7v9Zm0-16v5h7V4h-7Z"/></svg>
                        Tableau de bord
                    </a>
                    <a class="side-link {{ currentRoute starts with 'app_inmate' ? 'is-active' }}" href="{{ path('app_inmate_index') }}">
                        <svg class="side-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm-7 9a7 7 0 0 1 14 0H5Z"/></svg>
                        Detenus
                    </a>
                    <a class="side-link {{ currentRoute starts with 'app_structure' ? 'is-active' }}" href="{{ path('app_structure_cells') }}">
                        <svg class="side-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 21V3h16v18H4Zm4-12h3V6H8v3Zm5 0h3V6h-3v3Zm-5 5h3v-3H8v3Zm5 0h3v-3h-3v3Zm-5 5h3v-3H8v3Zm5 0h3v-3h-3v3Z"/></svg>
                        Cellules
                    </a>
                    <a class="side-link {{ currentRoute starts with 'app_incident' ? 'is-active' }}" href="{{ path('app_incident_index') }}">
                        <svg class="side-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 2 20h20L12 2Zm1 15h-2v-2h2v2Zm0-4h-2V8h2v5Z"/></svg>
                        Incidents
                    </a>
                </nav>
            </details>

            <div class="app-shell">
                <aside class="app-sidebar" aria-label="Navigation principale">
                    <a class="brand" href="{{ path(dashboardRoute) }}">
                        <img class="brand-logo" src="{{ asset('logo.png') }}" alt="PAS">
                        <span class="brand-copy">
                            <strong>Prison</strong>
                            <small>Administrator System</small>
                        </span>
                    </a>

                    <nav class="side-nav">
                        <a class="side-link {{ currentRoute in dashboardRoutes ? 'is-active' }}" href="{{ path(dashboardRoute) }}">
                            <svg class="side-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 13h7V4H4v9Zm0 7h7v-5H4v5Zm9 0h7v-9h-7v9Zm0-16v5h7V4h-7Z"/></svg>
                            Tableau de bord
                        </a>
                        <a class="side-link {{ currentRoute starts with 'app_inmate' ? 'is-active' }}" href="{{ path('app_inmate_index') }}">
                            <svg class="side-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm-7 9a7 7 0 0 1 14 0H5Z"/></svg>
                            Detenus
                        </a>
                        <a class="side-link {{ currentRoute starts with 'app_structure' ? 'is-active' }}" href="{{ path('app_structure_cells') }}">
                            <svg class="side-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 21V3h16v18H4Zm4-12h3V6H8v3Zm5 0h3V6h-3v3Zm-5 5h3v-3H8v3Zm5 0h3v-3h-3v3Zm-5 5h3v-3H8v3Zm5 0h3v-3h-3v3Z"/></svg>
                            Cellules
                        </a>
                        <a class="side-link {{ currentRoute starts with 'app_incident' ? 'is-active' }}" href="{{ path('app_incident_index') }}">
                            <svg class="side-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 2 20h20L12 2Zm1 15h-2v-2h2v2Zm0-4h-2V8h2v5Z"/></svg>
                            Incidents
                        </a>
                    </nav>

                    <div class="sidebar-note">
                        <span class="note-label">Modules visibles</span>
                        <p>Navigation limitee aux pages actuellement raccordees a Symfony.</p>
                    </div>
                </aside>

                <div class="app-main">
                    <header class="topbar">
                        <div>
                            <p class="topbar-title">{% block page_title %}{% if app.user %}Bonjour, {{ app.user.fullName }}{% else %}Vue d'ensemble{% endif %}{% endblock %}</p>
                            <span class="eyebrow">Vue d'ensemble du centre penitentiaire</span>
                        </div>
                        <div class="topbar-actions">
                            <label class="search-box">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10.5 4a6.5 6.5 0 0 1 5.16 10.45l4.44 4.45-1.4 1.4-4.45-4.44A6.5 6.5 0 1 1 10.5 4Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z"/></svg>
                                <input type="search" placeholder="Rechercher un detenu, un batiment...">
                            </label>
                            <span class="notification-dot" aria-label="Notifications">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22Zm7-6V11a7 7 0 0 0-5-6.7V3a2 2 0 1 0-4 0v1.3A7 7 0 0 0 5 11v5l-2 2v1h18v-1l-2-2Z"/></svg>
                            </span>
                            <span class="avatar-chip" aria-label="Profil administrateur"></span>
                        </div>
                    </header>

                    <main class="content">
                        {% block dashboard_body %}{% endblock %}
                    </main>
                </div>
            </div>

            {% if currentRoute != 'app_login' %}
                <a class="tablet-launcher {{ currentRoute in ['app_tablet_guard', 'app_guard_tablet'] ? 'is-active' }}" href="{{ path('app_tablet_guard') }}" aria-label="Acces tablette detenu">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h10a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm0 3v14h10V5H7Zm4 15h2v1h-2v-1Z"/></svg>
                </a>
            {% endif %}
        {% endblock %}
    </body>
</html>
