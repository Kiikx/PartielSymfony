{% extends 'base.html.twig' %}

{% block title %}Tableau de bord - PAS{% endblock %}
{% block page_title %}{% if app.user %}Bonjour, {{ app.user.fullName }}{% else %}Vue d'ensemble{% endif %}{% endblock %}

{% block body %}
    <section class="metric-strip" aria-label="Indicateurs principaux">
        <article class="metric-card metric-card-dark">
            <svg class="metric-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm-7 9a7 7 0 0 1 14 0H5Z"/></svg>
            <div>
                <p class="metric-label">Detenus</p>
                <p class="metric-value">{{ metrics.activeInmates }}</p>
                <p class="metric-meta">+{{ metrics.totalInmates }} dossiers</p>
            </div>
            <span class="mini-chart" aria-hidden="true"></span>
        </article>
        <article class="metric-card">
            <div>
                <p class="metric-label">Cellules occupees</p>
                <p class="metric-value">{{ metrics.activeAssignments }}</p>
                <p class="metric-meta">{{ metrics.occupancyRate }}% d'occupation</p>
            </div>
            <div class="ring" style="--value: {{ metrics.occupancyRate }}%">
                <strong>{{ metrics.occupancyRate }}%</strong>
            </div>
        </article>
        <article class="metric-card">
            <div>
                <p class="metric-label">Membres du staff</p>
                <p class="metric-value">{{ metrics.staffMembers }}</p>
                <p class="metric-meta">Comptes actifs en base</p>
            </div>
            <svg class="metric-icon metric-purple" viewBox="0 0 24 24" aria-hidden="true"><path d="M16 11a3 3 0 1 0-2.83-4h-2.34A3 3 0 1 0 8 11a5 5 0 0 0-5 5v3h8v-3a5 5 0 0 0-3-4.58A3 3 0 0 0 8 11h8Zm0 0a5 5 0 0 0-5 5v3h10v-3a5 5 0 0 0-5-5Z"/></svg>
        </article>
        <article class="metric-card">
            <div>
                <p class="metric-label">Incidents ouverts</p>
                <p class="metric-value">{{ metrics.openIncidents }}</p>
                <p class="metric-meta">{{ metrics.highIncidents }} a gravite elevee ou critique</p>
            </div>
            <svg class="metric-icon metric-red" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 4 5v6c0 5.2 3.4 9.9 8 11 4.6-1.1 8-5.8 8-11V5l-8-3Zm1 14h-2v-2h2v2Zm0-4h-2V7h2v5Z"/></svg>
        </article>
    </section>

    <section class="dashboard-layout">
        <div class="dashboard-main">
            <article class="panel map-panel">
                <div class="panel-header">
                    <h2>Occupation par batiment</h2>
                    <span class="tag">Tous les batiments</span>
                </div>
                <div class="prison-map" aria-label="Carte d'occupation">
                    {% for building in buildingOccupancy %}
                        <div class="map-building building-{{ loop.index }}"><span>{{ building.code ?: building.name }}<br><strong>{{ building.rate }}%</strong></span></div>
                    {% else %}
                        <p class="empty-state map-empty">Aucun batiment renseigne en base.</p>
                    {% endfor %}
                    {% if buildingOccupancy is not empty %}
                        <div class="map-controls" aria-hidden="true"><span>+</span><span>-</span><span>◎</span></div>
                    {% endif %}
                </div>
            </article>

            <article class="panel">
                <div class="panel-header">
                    <h2>Derniers detenus</h2>
                    <a class="panel-link" href="{{ path('app_inmate_index') }}">Voir tous</a>
                </div>
                <div class="table-wrap">
                    <table class="data-table inmate-table">
                        <thead>
                            <tr>
                                <th scope="col">ID detenu</th>
                                <th scope="col">Nom</th>
                                <th scope="col">Batiment / cellule</th>
                                <th scope="col">Statut</th>
                                <th scope="col">Arrivee</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for inmate in recentInmates %}
                                {% set activeAssignment = null %}
                                {% for assignment in inmate.assignments %}
                                    {% if activeAssignment is null and assignment.active %}
                                        {% set activeAssignment = assignment %}
                                    {% endif %}
                                {% endfor %}
                                <tr>
                                    <td>{{ inmate.uid }}</td>
                                    <td>{{ inmate.fullName }}</td>
                                    <td>
                                        {% if activeAssignment and activeAssignment.cell %}
                                            {{ activeAssignment.cell.wing and activeAssignment.cell.wing.building ? activeAssignment.cell.wing.building.code : '-' }} / {{ activeAssignment.cell.number }}
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td><span class="status-badge blue">{{ inmate.status }}</span></td>
                                    <td>{{ inmate.arrivalDate ? inmate.arrivalDate|date('d/m/Y') : '-' }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td class="empty-state" colspan="5">Aucun detenu a afficher pour le moment.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </article>
        </div>

        <div class="dashboard-middle">
            <article class="panel agenda-panel">
                <div class="panel-header">
                    <h2>Planning du jour</h2>
                </div>
                <ul class="timeline-list">
                    {% for activity in todayActivities %}
                        <li class="timeline-item tone-blue">
                            <span class="timeline-time">{{ activity.scheduledAt|date('H:i') }}</span>
                            <span class="timeline-dot"></span>
                            <span class="timeline-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm-7 9a7 7 0 0 1 14 0H5Z"/></svg>
                            </span>
                            <span><strong>{{ activity.label }}</strong><small>{{ activity.location ?: activity.type }}</small></span>
                        </li>
                    {% else %}
                        <li class="empty-state">Aucune activite programmee aujourd'hui.</li>
                    {% endfor %}
                </ul>
                <span class="wide-link is-disabled">Voir tout le planning</span>
            </article>

            <article class="panel stats-panel">
                <div class="panel-header">
                    <h2>Statistiques rapides</h2>
                    <span class="tag">Base actuelle</span>
                </div>
                <div class="donut-wrap">
                    <div class="donut"><strong>{{ movementStats.total }}</strong><span>Mouvements</span></div>
                    <ul class="legend-list">
                        <li><span class="legend-dot green"></span>Transferts internes <strong>{{ movementStats.internal }}</strong></li>
                        <li><span class="legend-dot purple"></span>Transferts externes <strong>{{ movementStats.external }}</strong></li>
                        <li><span class="legend-dot orange"></span>Activites <strong>{{ movementStats.activities }}</strong></li>
                        <li><span class="legend-dot gray"></span>Affectations <strong>{{ movementStats.assignments }}</strong></li>
                    </ul>
                </div>
                <span class="wide-link is-disabled">Voir le rapport complet</span>
            </article>
        </div>

        <aside class="right-rail" aria-label="Alertes et notifications">
            <article class="panel">
                <div class="panel-header">
                    <h2>Alertes & Notifications</h2>
                    <a class="panel-link" href="{{ path('app_incident_index') }}">Voir tout</a>
                </div>
                <ul class="notification-list">
                    {% for notification in recentNotifications %}
                        <li>
                            <span class="notif-icon blue"></span>
                            <strong>{{ notification.subject }}</strong>
                            <small>{{ notification.channel }} - {{ notification.status }}</small>
                            <em>{{ notification.sentAt ? notification.sentAt|date('d/m H:i') : '-' }}</em>
                        </li>
                    {% else %}
                        {% for incident in recentIncidents %}
                            <li>
                                <span class="notif-icon red"></span>
                                <strong>{{ incident.title }}</strong>
                                <small>{{ incident.cell ? incident.cell.number : 'Lieu non renseigne' }} - {{ incident.status }}</small>
                                <em>{{ incident.occurredAt|date('d/m H:i') }}</em>
                            </li>
                        {% else %}
                            <li class="empty-state">Aucune notification ou alerte a afficher.</li>
                        {% endfor %}
                    {% endfor %}
                </ul>
            </article>

            <article class="panel activity-summary">
                <div class="panel-header">
                    <h2>Activites en cours</h2>
                    <span class="panel-link is-disabled">Voir tout</span>
                </div>
                <div class="summary-grid">
                    {% for activity in activitySummary %}
                        <span><strong>{{ activity.total }}</strong><small>{{ activity.type }}</small></span>
                    {% else %}
                        <span><strong>0</strong><small>Aucune activite</small></span>
                    {% endfor %}
                </div>
            </article>

            <article class="panel camera-panel">
                <div class="panel-header">
                    <h2>Cameras en direct</h2>
                    <span class="panel-link is-disabled">Voir toutes</span>
                </div>
                <div class="camera-grid">
                    <p class="empty-state">Aucun flux camera configure en base.</p>
                </div>
            </article>
        </aside>
    </section>
{% endblock %}
