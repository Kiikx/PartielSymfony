{% extends 'base.html.twig' %}

{% block title %}Declarer un incident - PAS{% endblock %}
{% block page_title %}Declarer un incident{% endblock %}

{% block dashboard_body %}
    <section class="page-head">
        <div>
            <span class="eyebrow">Surete</span>
            <h1>Declaration d'incident</h1>
            <p>Saisie rapide d'un signalement terrain et de son niveau de priorite.</p>
        </div>
        <a class="button" href="{{ path('app_incident_index') }}">Retour incidents</a>
    </section>

    <section class="form-layout">
        <form class="panel form-panel">
            <div class="panel-header">
                <h2>Signalement</h2>
                <span class="tag">Priorite</span>
            </div>
            <div class="form-grid">
                <label>Titre <input type="text" name="title"></label>
                <label>Cellule / lieu <input type="text" name="location"></label>
                <label>Gravite
                    <select name="severity">
                        <option>Faible</option>
                        <option>Moyenne</option>
                        <option>Elevee</option>
                        <option>Critique</option>
                    </select>
                </label>
                <label>Statut
                    <select name="status">
                        <option>Ouvert</option>
                        <option>En traitement</option>
                        <option>Clos</option>
                    </select>
                </label>
                <label class="form-wide">Description
                    <textarea name="description" rows="5"></textarea>
                </label>
            </div>
            <div class="form-actions">
                <button class="button button-primary" type="button" disabled>Enregistrer</button>
                <span class="form-state">Sauvegarde back a raccorder</span>
            </div>
        </form>
    </section>
{% endblock %}
