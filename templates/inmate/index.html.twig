{% extends 'base.html.twig' %}

{% block title %}Detenus - PAS{% endblock %}
{% block page_title %}Detenus{% endblock %}

{% block dashboard_body %}
    <section class="page-head">
        <div>
            <span class="eyebrow">Dossiers detenus</span>
            <h1>Recherche et suivi des detenus</h1>
            <p>Consultez les dossiers, statuts et niveaux de securite remontes par la base.</p>
        </div>
        <div class="button-row">
            <a class="button button-primary" href="{{ path('app_inmate_new') }}">Nouveau detenu</a>
            <a class="button" href="{{ path('app_inmate_export') }}">Exporter</a>
        </div>
    </section>

    <section class="metric-strip page-metrics" aria-label="Synthese detenus">
        <article class="metric-card metric-card-dark">
            <svg class="metric-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm-7 9a7 7 0 0 1 14 0H5Z"/></svg>
            <div>
                <p class="metric-label">Dossiers</p>
                <p class="metric-value">{{ stats.total }}</p>
                <p class="metric-meta">Total en base</p>
            </div>
        </article>
        <article class="metric-card">
            <div>
                <p class="metric-label">Incarceres</p>
                <p class="metric-value">{{ stats.incarcerated }}</p>
                <p class="metric-meta">Population active</p>
            </div>
        </article>
        <article class="metric-card">
            <div>
                <p class="metric-label">Sortis</p>
                <p class="metric-value">{{ stats.released }}</p>
                <p class="metric-meta">Dossiers clotures</p>
            </div>
        </article>
        <article class="metric-card">
            <div>
                <p class="metric-label">Transferes</p>
                <p class="metric-value">{{ stats.externalTransfers }}</p>
                <p class="metric-meta">Transferts externes</p>
            </div>
        </article>
    </section>

    <form class="filter-bar" method="get" action="{{ path('app_inmate_index') }}" aria-label="Filtres detenus">
        <label>
            UID
            <input type="search" name="uid" value="{{ filters.uid }}" placeholder="Rechercher un UID">
        </label>
        <label>
            Statut
            <select name="status">
                <option value="">Tous les statuts</option>
                {% for status in statuses %}
                    <option value="{{ status }}" {{ filters.status == status ? 'selected' }}>{{ status }}</option>
                {% endfor %}
            </select>
        </label>
        <label>
            Niveau
            <select name="securityLevel">
                <option value="">Tous les niveaux</option>
                {% for level in securityLevels %}
                    <option value="{{ level }}" {{ filters.securityLevel == level ? 'selected' }}>{{ level }}</option>
                {% endfor %}
            </select>
        </label>
        <button class="button" type="submit">Filtrer</button>
    </form>

    <section class="entity-layout">
        <article class="panel entity-list-panel">
        <div class="panel-header">
            <h2>Liste des detenus</h2>
            <span class="tag">{{ databaseReady ? 'Base disponible' : 'Migration requise' }}</span>
        </div>
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th scope="col">UID</th>
                        <th scope="col">Nom</th>
                        <th scope="col">Statut</th>
                        <th scope="col">Securite</th>
                        <th scope="col">Arrivee</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for inmate in inmates %}
                    <tr>
                        <th scope="row">{{ inmate.uid }}</th>
                        <td>
                            <span class="entity-name">{{ inmate.fullName }}</span>
                        </td>
                        <td><span class="status-badge status-{{ inmate.status|lower|replace({'_': '-'}) }}">{{ inmate.status }}</span></td>
                        <td><span class="severity-pill level-{{ inmate.securityLevel|lower }}">{{ inmate.securityLevel }}</span></td>
                        <td>{{ inmate.arrivalDate ? inmate.arrivalDate|date('d/m/Y') : '-' }}</td>
                        <td class="table-actions">
                            <a class="table-link" href="{{ path('app_inmate_show', {id: inmate.id}) }}">Voir</a>
                            <a class="table-link" href="{{ path('app_inmate_edit', {id: inmate.id}) }}">Modifier</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td class="empty-state" colspan="6">Aucun detenu a afficher pour le moment.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        </article>

        <aside class="panel insight-panel">
            <div class="panel-header">
                <h2>Repartition</h2>
                <span class="tag">Statuts</span>
            </div>
            <div class="insight-stack">
                <div class="insight-row">
                    <span>Incarceres</span>
                    <strong>{{ stats.incarcerated }}</strong>
                </div>
                <div class="progress-track"><span style="width: {{ stats.total > 0 ? (stats.incarcerated / stats.total * 100)|round : 0 }}%"></span></div>
                <div class="insight-row">
                    <span>Sortis</span>
                    <strong>{{ stats.released }}</strong>
                </div>
                <div class="progress-track is-muted"><span style="width: {{ stats.total > 0 ? (stats.released / stats.total * 100)|round : 0 }}%"></span></div>
                <div class="insight-row">
                    <span>Transferes</span>
                    <strong>{{ stats.externalTransfers }}</strong>
                </div>
                <div class="progress-track is-warning"><span style="width: {{ stats.total > 0 ? (stats.externalTransfers / stats.total * 100)|round : 0 }}%"></span></div>
            </div>
        </aside>
    </section>
{% endblock %}
